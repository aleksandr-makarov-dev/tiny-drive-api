{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "NpgSqlConnection": "Host=localhost;Port=5432;Database=tiny_drive;Username=postgres"
  },
  "ObjectStorage": {
    "Endpoint": "http://localhost:9000",
    "BucketName": "tiny-drive"
  }
}
